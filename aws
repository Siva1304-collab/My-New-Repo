CREATE OR REPLACE PACKAGE student_pkg AS
   PROCEDURE add_student(p_id NUMBER, p_name VARCHAR2, p_marks NUMBER);
   FUNCTION get_grade(p_marks NUMBER) RETURN VARCHAR2;
END;
/

CREATE OR REPLACE PACKAGE BODY student_pkg AS

   PROCEDURE add_student(p_id NUMBER, p_name VARCHAR2, p_marks NUMBER) IS
   BEGIN
      INSERT INTO students VALUES (p_id, p_name, p_marks);
   END;

   FUNCTION get_grade(p_marks NUMBER) RETURN VARCHAR2 IS
   BEGIN
      IF p_marks >= 90 THEN
         RETURN 'A';
      ELSIF p_marks >= 75 THEN
         RETURN 'B';
      ELSE
         RETURN 'C';
      END IF;
   END;

END;
/

